# ============================================================
# NotaLens - Environment Variables
# Copy file ini ke .env.local dan isi nilainya
# JANGAN commit .env.local ke GitHub!
# ============================================================

# Supabase - ambil dari dashboard.supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret - buat string random panjang, minimal 32 karakter
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-dengan-random-string-yang-panjang

# FastAPI URL (untuk development local)
FASTAPI_URL=http://localhost:8000
